# Copy to .env.local and fill in real values. Never commit real credentials.
# Dummy values below are sufficient for placeholder-mode development and tests.

# Firebase service account (Firestore, server-side only)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"

# Gemini runtime brain (owner-supplied; required at Phase 1+ runtime)
GEMINI_API_KEY=replace-me

# Media provider switch: placeholder | gemini
MEDIA_PROVIDER=placeholder

# Learner-state store: firestore (production) | dev-file (credential-less local dev)
DATA_STORE=firestore

# Model identifier overrides (defaults live in lib/config.ts, the only home of model strings)
# GEMINI_MODEL_FAST=
# GEMINI_MODEL_DEEP=
# GEMINI_MODEL_LIVE=
# IMAGE_MODEL=
