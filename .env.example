# Copy to .env.local and fill in real values. Never commit real credentials.
# The values below are sufficient for placeholder-mode development and tests.

# Gemini runtime brain (owner-supplied; required at Phase 1+ runtime).
# The only always-required secret: without it the brain-dependent surfaces
# (listening evaluation, scenario dialogue, writing correction, exam
# generation) render recoverable error states rather than working.
GEMINI_API_KEY=replace-me

# Media provider switch: placeholder | gemini
MEDIA_PROVIDER=placeholder

# Learner-state store: postgres (deployed default) | firestore | dev-file.
# Local development normally wants dev-file, which needs no credentials at
# all and keeps learner state in a local JSON file.
DATA_STORE=dev-file

# --- postgres store (DATA_STORE=postgres) ---------------------------------
# Required when DATA_STORE=postgres, ignored otherwise. The adapter creates
# its own table on first use, so an empty database is enough. On the VPS this
# points at the Coolify Postgres over the internal Docker network, so the
# database is never publicly exposed.
# DATABASE_URL=postgresql://user:password@host:5432/detutor

# --- firestore store (DATA_STORE=firestore) -------------------------------
# Required only when DATA_STORE=firestore, ignored otherwise. Do not invent
# placeholder values to satisfy the schema under another store; the config
# refinement asks for these exactly when they are actually read.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"

# --- optional overrides ---------------------------------------------------
# The dev-file store's backing file; e2e points this at its own file so test
# runs never touch local learner data.
# DEV_STORE_FILE=.dev-data/store.json

# Model identifier overrides (defaults live in lib/config.ts, the only home
# of model strings)
# GEMINI_MODEL_FAST=
# GEMINI_MODEL_DEEP=
# GEMINI_MODEL_LIVE=
# IMAGE_MODEL=
# GEMINI_MODEL_TTS=
