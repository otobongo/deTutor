# Copy this file to .env.local (gitignored) and paste your real values.
# The app runs fully in placeholder mode with just the defaults below;
# each key you add unlocks the matching capability.

# ------------------------------------------------------------------
# 1. Gemini (the runtime brain)
#    Get a key at https://aistudio.google.com/apikey
#    Unlocks: listening evaluation, scenario dialogues, writing
#    correction, reading generation, placement feedback.
# ------------------------------------------------------------------
GEMINI_API_KEY=paste-your-gemini-key-here

# ------------------------------------------------------------------
# 2. Firebase (Firestore persistence)
#    Firebase console -> Project settings -> Service accounts ->
#    Generate new private key. Copy the three values from the JSON.
#    Keep the private key in double quotes with \n intact.
# ------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\npaste-the-key-body-here\n-----END PRIVATE KEY-----\n"

# ------------------------------------------------------------------
# 3. Switches
#    DATA_STORE: dev-file stores learner progress in .dev-data/ (no
#    credentials needed). Flip to firestore once section 2 is real, or
#    to postgres for a self-hosted database you own (GT-D2) — then set
#    DATABASE_URL below and section 2 can stay as dummy values.
#    MEDIA_PROVIDER: stays placeholder until Phase 5 media generation.
# ------------------------------------------------------------------
DATA_STORE=dev-file
MEDIA_PROVIDER=placeholder

# Required only when DATA_STORE=postgres. The adapter creates its table
# on first use, so point it at an empty database and nothing else.
# DATABASE_URL=postgresql://user:password@host:5432/detutor

# ------------------------------------------------------------------
# 4. Optional model overrides (defaults live in lib/config.ts)
# ------------------------------------------------------------------
# GEMINI_MODEL_FAST=
# GEMINI_MODEL_DEEP=
# GEMINI_MODEL_LIVE=
# IMAGE_MODEL=
