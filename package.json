{
  "name": "german-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run guards && npm run test && npm run test:e2e",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "guards": "node scripts/guards/run-guards.mjs",
    "seed:curriculum": "tsx db/seed/run-seed-curriculum.ts",
    "ingest:vocab": "tsx scripts/ingest-vocab.ts",
    "seed:vocab": "tsx db/seed/run-seed-vocab.ts",
    "enrich:vocab": "tsx scripts/enrich-vocab.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "firebase-admin": "^14.1.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-fsrs": "^5.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
